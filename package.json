{
  "name": "the-threshold",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "A source-driven Kane Parsons research archive and static dispatch site.",
  "scripts": {
    "dev": "eleventy --serve",
    "validate": "node scripts/validate-data.mjs",
    "build": "npm run validate && eleventy",
    "check:links": "node scripts/check-links.mjs",
    "new:edition": "node scripts/create-edition.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@11ty/eleventy": "3.1.6",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1"
  }
}
